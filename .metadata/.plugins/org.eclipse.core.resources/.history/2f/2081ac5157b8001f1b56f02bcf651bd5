package core;

class User{
	int id;
	String name;
	String address;
	long contact;
	public void setId(int id) {
		this.id = id;
	}
}
public class P015_Encapsulation {
	public static void main(String[] args) {
		User u1 = new User();
		u1.id=1;
		u1.name= "java";
		u1.address = "ahmedabad";
		u1.contact = 98746513;
		System.out.println(u1.address);
	}
}
