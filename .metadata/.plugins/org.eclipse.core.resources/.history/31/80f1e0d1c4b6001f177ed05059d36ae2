package core;

class Overload {
	public int add(int a, int b) {
		return a + b;
	}

	public int add(int a, int b, int c) {
		return a + b + c;
	}
}

public class P012_Polymorphism {
	public static void main(String[] args) {
		Overload o =new Overload();
		int res =  o.add(1, 2);
		System.out.println(res);
	}
}
