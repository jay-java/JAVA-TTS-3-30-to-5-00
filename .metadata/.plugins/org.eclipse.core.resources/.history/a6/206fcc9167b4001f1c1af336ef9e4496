package core;

class Data{
	int i;
	String name;
	Data(){
		System.out.println("default cons on data class");
	}
	Data(){
		
	}
	public void call() {
		System.out.println("call in data class");
	}
	public void show() {
		System.out.println("i = "+i+" name = "+name);
	}
}
public class P010_Constructor {
	public static void main(String[] args) {
		Data d = new Data();
		d.call();
		d.show();
	}
}
