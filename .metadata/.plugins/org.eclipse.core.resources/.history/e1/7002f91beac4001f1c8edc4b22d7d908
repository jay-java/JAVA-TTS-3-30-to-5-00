package core;

class Employee{
	int emp_id;
	String name;
	double salary;
	String addres;
	Employee(int emp_id,String name,double salary,String address){
		this.emp_id = emp_id;
		this.name = name;
		this.salary = salary;
		this.addres = address;
	}
	@Override
	public String toString() {
		return "Employee [emp_id=" + emp_id + ", name=" + name + ", salary=" + salary + ", addres=" + addres + "]";
	}
	
}
